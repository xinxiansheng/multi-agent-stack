{
  "meta": {
    "lastTouchedVersion": "2026.2.14",
    "lastTouchedAt": "__GENERATED__"
  },
  "logging": {
    "level": "info"
  },
  "auth": {
    "profiles": {
      "minimax:default": {
        "provider": "minimax",
        "mode": "api_key"
      },
      "anthropic:manual": {
        "provider": "anthropic",
        "mode": "token"
      },
      "openai-codex:default": {
        "provider": "openai-codex",
        "mode": "oauth"
      },
      "newapi:default": {
        "provider": "newapi",
        "mode": "api_key"
      }
    }
  },
  "models": {
    "mode": "merge",
    "providers": {
      "minimax": {
        "baseUrl": "https://api.minimaxi.com/anthropic",
        "api": "anthropic-messages",
        "models": [
          {
            "id": "MiniMax-M2.5",
            "name": "MiniMax M2.5",
            "reasoning": true,
            "input": ["text"],
            "cost": { "input": 15, "output": 60, "cacheRead": 2, "cacheWrite": 10 },
            "contextWindow": 200000,
            "maxTokens": 8192
          }
        ]
      },
      "newapi": {
        "baseUrl": "${NEWAPI_BASE_URL}",
        "api": "openai-completions",
        "models": [
          {
            "id": "gemini-3-pro-preview",
            "name": "Gemini 3 Pro",
            "reasoning": true,
            "input": ["text", "image"],
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
            "contextWindow": 1000000,
            "maxTokens": 65536
          },
          {
            "id": "gemini-2.0-flash",
            "name": "Gemini 2.0 Flash",
            "reasoning": false,
            "input": ["text", "image"],
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
            "contextWindow": 1000000,
            "maxTokens": 8192
          },
          {
            "id": "seed-1-8-251228",
            "name": "Doubao Seed 1.8",
            "reasoning": true,
            "input": ["text"],
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
            "contextWindow": 128000,
            "maxTokens": 8192
          },
          {
            "id": "claude-sonnet-4-5-20250929",
            "name": "Claude Sonnet 4.5 (NewAPI)",
            "reasoning": true,
            "input": ["text", "image"],
            "cost": { "input": 3, "output": 15, "cacheRead": 0.3, "cacheWrite": 3.75 },
            "contextWindow": 200000,
            "maxTokens": 8192
          },
          {
            "id": "claude-opus-4-5-20251101",
            "name": "Claude Opus 4.5 (NewAPI)",
            "reasoning": true,
            "input": ["text", "image"],
            "cost": { "input": 15, "output": 75, "cacheRead": 1.5, "cacheWrite": 18.75 },
            "contextWindow": 200000,
            "maxTokens": 8192
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "${PRIMARY_MODEL}",
        "fallbacks": [
          "${FALLBACK_MODEL_1}",
          "${FALLBACK_MODEL_2}"
        ]
      },
      "models": {
        "anthropic/claude-opus-4-6": { "alias": "opus" },
        "openai-codex/gpt-5.2": { "alias": "GPT-5.2" },
        "openai-codex/gpt-5.2-codex": { "alias": "Codex" },
        "openai-codex/gpt-5.3-codex": { "alias": "Codex-5.3" },
        "minimax/MiniMax-M2.5": { "alias": "Minimax" },
        "newapi/gemini-3-pro-preview": { "alias": "Gemini3" },
        "newapi/gemini-2.0-flash": { "alias": "Flash" },
        "newapi/seed-1-8-251228": { "alias": "Doubao" },
        "newapi/claude-sonnet-4-5-20250929": { "alias": "Sonnet-NewAPI" },
        "newapi/claude-opus-4-5-20251101": { "alias": "Opus-NewAPI" }
      },
      "workspace": "${HOME_DIR}/.openclaw/workspace",
      "contextPruning": {
        "mode": "cache-ttl",
        "ttl": "1h"
      },
      "compaction": {
        "mode": "safeguard"
      },
      "heartbeat": {
        "every": "1h"
      },
      "maxConcurrent": 4,
      "subagents": {
        "maxConcurrent": 8
      }
    },
    "list": [
      {
        "id": "main",
        "default": true,
        "name": "Nexus",
        "workspace": "${HOME_DIR}/.openclaw/workspace",
        "agentDir": "${HOME_DIR}/.openclaw/agents/main/agent",
        "identity": {
          "name": "Nexus",
          "theme": "central hub",
          "emoji": "\u26a1"
        },
        "subagents": {
          "allowAgents": ["observer", "arbiter"]
        }
      },
      {
        "id": "arbiter",
        "name": "Arbiter",
        "workspace": "${HOME_DIR}/.openclaw/workspace-arbiter",
        "agentDir": "${HOME_DIR}/.openclaw/agents/arbiter/agent",
        "model": {
          "primary": "anthropic/claude-opus-4-6",
          "fallbacks": []
        },
        "identity": {
          "name": "Arbiter",
          "theme": "strategic advisor",
          "emoji": "\u2696\ufe0f"
        },
        "subagents": {
          "allowAgents": ["main"]
        }
      },
      {
        "id": "observer",
        "name": "Observer",
        "workspace": "${HOME_DIR}/.openclaw/workspace-observer",
        "agentDir": "${HOME_DIR}/.openclaw/agents/observer/agent",
        "model": {
          "primary": "${OBSERVER_PRIMARY_MODEL}",
          "fallbacks": ["${OBSERVER_FALLBACK_MODEL}"]
        },
        "identity": {
          "name": "Observer",
          "theme": "intelligence analyst",
          "emoji": "\ud83d\udc41\ufe0f"
        },
        "subagents": {
          "allowAgents": ["main"]
        }
      }
    ]
  },
  "tools": {
    "media": {
      "audio": {
        "enabled": true,
        "models": [
          {
            "capabilities": ["audio"],
            "type": "cli",
            "command": "whisper",
            "args": [
              "--model", "${WHISPER_MODEL}",
              "--language", "${WHISPER_LANGUAGE}",
              "--output_format", "txt",
              "--output_dir", "{{OutputDir}}",
              "{{MediaPath}}"
            ]
          }
        ]
      }
    },
    "agentToAgent": {
      "enabled": true
    }
  },
  "bindings": [
    {
      "agentId": "observer",
      "match": {
        "channel": "telegram",
        "accountId": "observer"
      }
    }
  ],
  "messages": {
    "ackReactionScope": "group-mentions"
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto"
  },
  "hooks": {
    "internal": {
      "enabled": true,
      "entries": {
        "boot-md": { "enabled": true },
        "command-logger": { "enabled": true },
        "session-memory": { "enabled": true }
      }
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "dmPolicy": "pairing",
      "botToken": "${TG_NEXUS_BOT_TOKEN}",
      "groupPolicy": "allowlist",
      "streamMode": "partial",
      "proxy": "${HTTP_PROXY}",
      "accounts": {
        "default": {
          "name": "Nexus \u26a1",
          "dmPolicy": "pairing",
          "groupPolicy": "allowlist",
          "streamMode": "partial"
        },
        "observer": {
          "name": "Observer \ud83d\udc41\ufe0f",
          "enabled": true,
          "dmPolicy": "pairing",
          "botToken": "${TG_OBSERVER_BOT_TOKEN}",
          "allowFrom": ["${TG_OWNER_USER_ID}"],
          "groupPolicy": "allowlist",
          "streamMode": "partial"
        }
      }
    }
  },
  "gateway": {
    "port": ${GATEWAY_PORT},
    "mode": "local",
    "bind": "loopback",
    "auth": {
      "mode": "token",
      "token": "${GATEWAY_AUTH_TOKEN}"
    },
    "tailscale": {
      "mode": "off",
      "resetOnExit": false
    }
  },
  "skills": {
    "install": {
      "nodeManager": "npm"
    }
  },
  "plugins": {
    "entries": {
      "telegram": { "enabled": true }
    }
  }
}
