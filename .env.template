# ============================================================
# OpenClaw Multi-Agent Stack - Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.template .env && nano .env
# ============================================================

# --- Machine Identity ---
# Username on this Mac (auto-detected by bootstrap if left blank)
MACHINE_USER=
# Home directory (auto-detected)
HOME_DIR=

# --- Network ---
# HTTP/HTTPS proxy (leave blank if not needed)
HTTP_PROXY=http://127.0.0.1:7890
# Tailscale IP of this machine (optional, for remote access)
TAILSCALE_IP=

# --- OpenClaw Gateway ---
GATEWAY_PORT=18789
GATEWAY_AUTH_TOKEN=__GENERATE_ME__

# --- AI Model Providers ---

# Anthropic (primary - Claude Opus)
ANTHROPIC_API_KEY=

# OpenAI Codex (fallback)
# Uses OAuth flow - run: openclaw auth login openai-codex
OPENAI_CODEX_AUTH=oauth

# MiniMax (final fallback)
MINIMAX_API_KEY=

# NewAPI (Gemini / Doubao / other routed models)
NEWAPI_BASE_URL=https://newapi.sms88.info/v1
NEWAPI_API_KEY=

# --- Primary Model Selection ---
# Options: anthropic/claude-opus-4-6, openai-codex/gpt-5.2, minimax/MiniMax-M2.5
PRIMARY_MODEL=anthropic/claude-opus-4-6
FALLBACK_MODEL_1=openai-codex/gpt-5.2
FALLBACK_MODEL_2=minimax/MiniMax-M2.5

# Observer uses cheaper model by default
OBSERVER_PRIMARY_MODEL=openai-codex/gpt-5.2
OBSERVER_FALLBACK_MODEL=minimax/MiniMax-M2.5

# --- Telegram Bots ---
# Main bot (Nexus dispatcher)
TG_NEXUS_BOT_TOKEN=
# Observer bot
TG_OBSERVER_BOT_TOKEN=
# Your Telegram user ID (for allowFrom)
TG_OWNER_USER_ID=

# --- OpenViking (Knowledge Base) ---
OPENVIKING_PORT=2033
# Embedding model (doubao-embedding-vision via NewAPI)
OPENVIKING_EMBEDDING_MODEL=doubao-embedding-vision

# --- RSSHub ---
RSSHUB_PORT=2035

# --- Whisper (Voice) ---
WHISPER_MODEL=turbo
WHISPER_LANGUAGE=zh

# --- Optional: Additional Agent Bot Tokens ---
# Fill these in when you create new agents via ./new-agent.sh
# TG_ARBITER_BOT_TOKEN=
# TG_PRISM_BOT_TOKEN=
# TG_FORGE_BOT_TOKEN=
# TG_WINGMAN_BOT_TOKEN=
# TG_VITALS_BOT_TOKEN=
