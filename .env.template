# ============================================================
# OpenClaw Multi-Agent Stack - Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.template .env && nano .env
# ============================================================

# --- Machine Identity ---
# Username on this Mac (auto-detected by bootstrap if left blank)
MACHINE_USER=
# Home directory (auto-detected)
HOME_DIR=

# --- Network ---
# HTTP/HTTPS proxy (leave blank if not needed)
HTTP_PROXY=http://127.0.0.1:7890
# Tailscale IP of this machine (optional, for remote access)
TAILSCALE_IP=

# --- OpenClaw Gateway ---
GATEWAY_PORT=18789
GATEWAY_AUTH_TOKEN=__GENERATE_ME__

# --- AI Model Providers ---
# The system uses a multi-provider, multi-model architecture.
# Each provider has different strengths; configure what you have.

# Provider 1: Anthropic (official API — highest quality)
# Models: claude-opus-4-6
ANTHROPIC_API_KEY=

# Provider 2: OpenAI Codex (OAuth-based)
# Models: gpt-5.2, gpt-5.2-codex, gpt-5.3-codex
# Run: openclaw auth login openai-codex
OPENAI_CODEX_AUTH=oauth

# Provider 3: MiniMax (cost-effective reasoning)
# Models: MiniMax-M2.5
MINIMAX_API_KEY=

# Provider 4: NewAPI (aggregated proxy — Gemini, Doubao, Claude variants)
# Routes multiple model families through a single OpenAI-compatible endpoint.
# Models: gemini-3-pro-preview, gemini-2.0-flash, seed-1-8-251228 (Doubao),
#          claude-sonnet-4-5-20250929, claude-opus-4-5-20251101
NEWAPI_BASE_URL=https://newapi.sms88.info/v1
NEWAPI_API_KEY=

# --- Model Selection & Fallback Chain ---
# Format: provider/model-id
# The system cascades: primary → fallback_1 → fallback_2
#
# Available models by provider:
#   anthropic   : claude-opus-4-6
#   openai-codex: gpt-5.2, gpt-5.2-codex, gpt-5.3-codex
#   minimax     : MiniMax-M2.5
#   newapi      : gemini-3-pro-preview, gemini-2.0-flash, seed-1-8-251228,
#                 claude-sonnet-4-5-20250929, claude-opus-4-5-20251101

# Default agent model chain
PRIMARY_MODEL=anthropic/claude-opus-4-6
FALLBACK_MODEL_1=openai-codex/gpt-5.2
FALLBACK_MODEL_2=minimax/MiniMax-M2.5

# Observer agent (bulk processing — prefer cheaper models)
OBSERVER_PRIMARY_MODEL=openai-codex/gpt-5.2
OBSERVER_FALLBACK_MODEL=minimax/MiniMax-M2.5

# --- Task-Specific Model Routing ---
# These control which models are used for specific workloads,
# independent of the agent's primary model.

# Frontend/UI development (Gemini 3 Pro excels at component generation)
FRONTEND_MODEL=newapi/gemini-3-pro-preview
# Code-specialized tasks
CODE_MODEL=openai-codex/gpt-5.2-codex
# Ultra-long context analysis (1M tokens)
LONG_CONTEXT_MODEL=newapi/gemini-3-pro-preview
# Chinese-optimized tasks (free via Volcengine)
CHINESE_MODEL=newapi/seed-1-8-251228
# Cost-free batch processing
BATCH_MODEL=newapi/gemini-2.0-flash

# --- Telegram Bots ---
# Main bot (Nexus dispatcher)
TG_NEXUS_BOT_TOKEN=
# Observer bot
TG_OBSERVER_BOT_TOKEN=
# Your Telegram user ID (for allowFrom)
TG_OWNER_USER_ID=

# --- Observer Pipeline ---
# LLM for Tier-1/Tier-2 filtering (cheap, fast model)
LLM_FILTER_MODEL=gemini-2.0-flash
LLM_SCORE_MODEL=gemini-2.0-flash
LLM_EXTRACT_MODEL=gemini-2.0-flash
# LLM for daily briefing (stronger model)
LLM_DAILY_MODEL=gemini-3-pro-preview

# --- OpenViking (Knowledge Base & Semantic Search) ---
OPENVIKING_PORT=2033
OPENVIKING_DASHBOARD_PORT=2034
# Volcengine (ByteDance) for embeddings — required for OpenViking
# Get keys at: https://console.volcengine.com/
VOLCENGINE_API_KEY=
VOLCENGINE_EMBED_MODEL=
VOLCENGINE_VLM_MODEL=

# --- RSSHub ---
RSSHUB_PORT=2035
# "docker" = use docker-compose; "local" = run via node directly
RSSHUB_MODE=local

# --- WeRSS (WeChat Official Account RSS) ---
# Set to "true" to enable WeRSS setup
WERSS_ENABLED=false
WERSS_PORT=8001

# --- Whisper (Voice) ---
WHISPER_MODEL=turbo
WHISPER_LANGUAGE=zh

# --- Optional: Additional Agent Bot Tokens ---
# Fill these in when you create new agents via ./new-agent.sh
# TG_ARBITER_BOT_TOKEN=
# TG_PRISM_BOT_TOKEN=
# TG_FORGE_BOT_TOKEN=
# TG_WINGMAN_BOT_TOKEN=
# TG_VITALS_BOT_TOKEN=
