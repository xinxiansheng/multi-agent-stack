<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>ai.openclaw.observer.collect</string>
    <key>ProgramArguments</key>
    <array>
        <string>__HOMEBREW_PREFIX__/bin/openclaw</string>
        <string>run</string>
        <string>--agent</string>
        <string>observer</string>
        <string>--prompt</string>
        <string>Execute a collection round: randomly sample ~23% of sources, filter, score, extract knowledge cards, and archive. Push any signals scoring >=85 immediately.</string>
    </array>
    <key>StartInterval</key>
    <integer>14400</integer>
    <key>StandardOutPath</key>
    <string>__HOME__/.openclaw/logs/observer-collect.log</string>
    <key>StandardErrorPath</key>
    <string>__HOME__/.openclaw/logs/observer-collect.err.log</string>
    <key>EnvironmentVariables</key>
    <dict>
        <key>HOME</key>
        <string>__HOME__</string>
        <key>PATH</key>
        <string>__HOMEBREW_PREFIX__/bin:/usr/local/bin:/usr/bin:/bin</string>
        <key>HTTPS_PROXY</key>
        <string>__HTTP_PROXY__</string>
    </dict>
</dict>
</plist>
